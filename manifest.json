{
   "action": {
      "default_title": "SUNO Copilot",
      "default_popup": "popup.html",
      "default_icon": {
         "16": "public/icon16.png",
         "32": "public/icon32.png",
         "48": "public/icon48.png",
         "128": "public/icon128.png"
      }
   },
   "icons": {
      "16": "public/icon16.png",
      "32": "public/icon32.png",
      "48": "public/icon48.png",
      "128": "public/icon128.png"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "contentScript.js" ],
      "matches": [ "https://suno.com/*" ]
   }],
   "description": "Download lyrics and MP3 files from Suno songs",
   "host_permissions": [
      "https://suno.com/*",
      "https://auth.suno.com/*",
      "https://*.suno.ai/*",
      "https://*/*"
   ],
   "permissions": [
      "activeTab",
      "cookies",
      "downloads",
      "scripting",
      "storage"
   ],
   "key": "",
   "manifest_version": 3,
   "minimum_chrome_version": "114",
   "name": "SUNO Copilot",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.0.9"
}
