{
  "name": "suno-copilot",
  "version": "0.0.9",
  "description": "Chrome extension to download lyrics (LRC), audio, cover, and video from Suno songs. Heavily WIP.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,js,mjs,html,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,html,css,json,md}\"",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/chrome": "^0.0.280",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "fflate": "0.8.3"
  }
}
